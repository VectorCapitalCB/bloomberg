<configuration>

	<appender name="Console" class="ch.qos.logback.core.ConsoleAppender">
		<encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
			<pattern>
				[%highlight(%date{ISO8601})] [%highlight(%level)] [%highlight(%logger{1})] [%highlight(%thread)] - %highlight(%msg) {%mdc}%n
			</pattern>
		</encoder>
	</appender>

	<appender name="File" class="ch.qos.logback.core.rolling.RollingFileAppender">
		<file>E:\VC\Feed-Handler\feed-handler-fix-proto\logs\fh_test.log</file>
		<rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
			<fileNamePattern>E:\VC\Feed-Handler\feed-handler-fix-proto\logs\bkp\fh_test.%d{yyyy-MM-dd}.log.gz</fileNamePattern>
			<maxHistory>30</maxHistory>
		</rollingPolicy>
		<encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
			<pattern>
				[%highlight(%date{ISO8601})] [%highlight(%level)] [%highlight(%logger{1})] [%highlight(%thread)] - %highlight(%msg) {%mdc}%n
			</pattern>
		</encoder>
	</appender>

	<logger name="cl.vc" level="INFO" additivity="false">
		<appender-ref ref="File" />
		<appender-ref ref="Console" />
	</logger>

	<logger name="fh-system-akka.actor" level="INFO" additivity="false">
		<appender-ref ref="File" />
		<appender-ref ref="Console" />
	</logger>

	<root level="WARN">
		<appender-ref ref="File" />
		<appender-ref ref="Console" />
	</root>

</configuration>